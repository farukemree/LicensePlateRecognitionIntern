# Sunucu - LAN icinden erisilebilsin diye 0.0.0.0, disariya kapatma isini ufw yapar.
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=plaka
DB_PASSWORD=degistir-bu-sifreyi
DB_NAME=plaka_takip
DB_SSLMODE=disable

# Redis (opsiyonel - ileride kesinlesecek; kapaliyken NoopCache devreye girer)
REDIS_ENABLED=false
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# Keycloak (OIDC) - backend sadece JWT/JWKS dogrulamasi yapar
AUTH_JWKS_URL=http://keycloak.local/realms/plaka-takip/protocol/openid-connect/certs
AUTH_ISSUER=http://keycloak.local/realms/plaka-takip
AUTH_AUDIENCE=

# Web Push (VAPID) - e-posta/SMTP YOK, sadece tarayici Web Push bildirimi
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
