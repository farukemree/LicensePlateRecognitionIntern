# ai-service örnek ortam değişkenleri
# Kullanım:  docker run --env-file ai-service/.env ...
# Hepsinin makul bir varsayılanı var; hiçbiri verilmezse servis yine çalışır.

# ─── Backend bağlantısı ────────────────────────────────────────────────
# Go backend'in ANPR webhook'u. (Eski kodda var olmayan bir .NET adresi
# yazılıydı; okunan plakalar bu yüzden hiçbir yere ulaşmıyordu.)
BACKEND_EVENTS_URL=http://localhost:8080/api/v1/anpr/events
# Go tarafı depot_id'yi UUID olarak ve ZORUNLU bekliyor — boş bırakılırsa
# event'ler reddedilebilir (servis açılışta uyarı basar).
DEPOT_ID=
# Yakalanan görselin backend'e gidecek URL'sinin kök adresi.
AI_SERVICE_PUBLIC_BASE_URL=http://localhost:8000
# Geriye dönük uyumluluk: base64 görselleri de gövdeye eklemek istersen true.
GORSEL_BASE64_GONDER=false

# ─── Kameralar ─────────────────────────────────────────────────────────
GEBZE_KAMERA_KULLANICI=admin
GEBZE_KAMERA_SIFRE=degistir-beni
GEBZE_KAMERA_HOST=2.200.168.165
GEBZE_GIRIS_PORT=8001
GEBZE_CIKIS_PORT=8003
# profile1 = ana akış, profile2 = alt akış (sahada profile2 de 2560x1440)
RTSP_PROFIL=profile2

# ─── Klasörler ─────────────────────────────────────────────────────────
CAPTURES_DIR=/app/captures
RETRAIN_DIR=/app/dataset/retrain

# ─── Loglama ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# sessiz | normal | ayrintili  (ayrintili = kare bazlı teşhis satırları)
LOG_SEVIYESI=normal

# ─── Teşhis (disk doldurur, sürekli açık bırakma) ─────────────────────
DEBUG_KARE_KAYDET=false
DEBUG_ORIJINAL_KARE_KAYDET=false

# ─── OCR / doğruluk ayarları ───────────────────────────────────────────
# Bu değerler yer gerçeği bilinen sahne kareleri üzerinde ÖLÇÜLEREK seçildi.
# Değiştirmeden önce ve sonra testler/ altındaki regresyon testlerini çalıştır.

# Kırpmanın ölçekleneceği hedef yükseklik. Doğruluğu belirleyen en önemli
# parametre: 230 -> %29 kare doğruluğu, 620 -> %88, 700+ tekrar düşüyor.
HEDEF_PLAKA_YUKSEKLIGI=620
AZAMI_OLCEK=10.0

# Kabul eşikleri (yanlış cevap vermektense susmak tercih edilir)
MIN_PLAKA_GUVENI=0.55
MIN_MUTABAKAT_KARE=2
TEK_KARE_KESIN_GUVEN=0.88
TEK_KARE_MIN_PAY=0.35
MIN_KANIT_PAYI=0.35

# Plaka kutusu geçerlilik filtreleri
PLAKA_CONF_ESIGI=0.35
PLAKA_IMGSZ=1280
PLAKA_MIN_GENISLIK=100
PLAKA_EN_BOY_MIN=1.6
PLAKA_EN_BOY_MAX=7.0
# Plaka, aracın bu orandan fazlasını kaplayamaz — kamyonet kapısındaki firma
# yazısını eler (gerçek plakalar %2.6-5.2, kapı yazısı %16.4 ölçüldü).
PLAKA_MAKS_ARAC_ORANI=0.10
PLAKA_ARAC_ZORUNLU=true

# Episode (araç geçişi) zamanlaması
ARAC_TESPIT_CONF=0.45
ARAC_AYRILMA_BOSLUGU=3.0
MAKS_TOPLAMA_SANIYESI=12.0
OCR_KARE_SAYISI=14
ERKEN_CIKIS_OY=3
ERKEN_CIKIS_GUVEN=0.95
VARYANT_ERKEN_CIKIS=0.95
MIN_KESKINLIK=60.0

# Aynı aracın tekrar tekrar kaydedilmesini engelleyen ayarlar
COOLDOWN_SANIYE=15.0
COOLDOWN_IOU_ESIGI=0.5
AYNI_PLAKA_BEKLEME=120.0

# Üst filigran/tarih-saat bandını karart (0 = kapalı)
UST_MASKE_ORANI=0.12
HEARTBEAT_SANIYE=120.0
