# ai-service ortam değişkenleri (örnek).
# Kopyala:  cp .env.example .env   ve değerleri kendi ortamına göre doldur.
# Docker'da:  docker run --env-file .env ...   ile geçirebilirsin.
# NOT: Tüm değerlerin makul varsayılanları vardır; hiçbiri verilmezse servis
#      eski davranışıyla çalışır (Gebze kameraları + localhost backend).

# --- 🎥 KAMERA (RTSP) ERİŞİMİ ---
# Kamera kullanıcı adı/şifresi ARTIK kaynak koda gömülü değil; buradan okunur.
GEBZE_KAMERA_KULLANICI=admin
# ⚠️ Gerçek şifreyi BURAYA yazma — bu dosya repoya commit ediliyor.
# Gerçek değeri sadece kendi .env dosyana koy.
GEBZE_KAMERA_SIFRE=degistir-beni
GEBZE_KAMERA_HOST=2.200.168.165
GEBZE_GIRIS_PORT=8001
GEBZE_CIKIS_PORT=8003
# profile1 = ana akış, profile2 = alt akış.
# Sahada profile2 de 2560x1440 veriyor ve doğrulanmış okumaların tamamı bu
# akıştan alındı; bant genişliği için varsayılan profile2.
RTSP_PROFIL=profile2

# --- 🔗 BACKEND (Go ANPR webhook) ENTEGRASYONU ---
# Okunan plaka + görüntü buraya POST edilir. Go backend varsayılan olarak
# :8080 üzerinde /api/v1/anpr/events dinler.
BACKEND_EVENTS_URL=http://localhost:8080/api/v1/anpr/events
# Go backend 'depot_id' alanını ZORUNLU ve UUID olarak bekler. Bu UUID'yi
# backend veritabanındaki depot tablosundan al. Boş bırakılırsa event reddedilebilir.
DEPOT_ID=
# Görseli base64 olarak da gövdeye eklemek istersen true yap (varsayılan: sadece image_url).
GORSEL_BASE64_GONDER=false

# --- 🖼️ YAKALANAN GÖRSEL SERVİSİ ---
# Okunan aracın görseli buraya yazılır ve /captures altında HTTP ile servis edilir.
CAPTURES_DIR=/app/captures
# image_url'ler bu taban adresle üretilir. Backend/tarayıcının AI servisine
# erişebildiği adresi yaz (LAN IP'si veya reverse-proxy adresi).
AI_SERVICE_PUBLIC_BASE_URL=http://localhost:8000
# Yeniden eğitim için etiketli görsellerin biriktiği klasör.
RETRAIN_DIR=/app/dataset/retrain

# --- 🐞 TEŞHİS / LOG ---
LOG_LEVEL=INFO
# sessiz | normal | ayrintili  (ayrintili = kare bazlı teşhis satırları)
LOG_SEVIYESI=normal
# Disk doldurur, sürekli açık bırakma. Ama hata teşhisinde çok işe yarar:
# kaydedilen kareyi açıp plakayı gözle okuyarak yer gerçeği çıkarılabilir.
DEBUG_KARE_KAYDET=false
DEBUG_ORIJINAL_KARE_KAYDET=false

# ═══════════════════════════════════════════════════════════════════════
# 🎯 OCR / DOĞRULUK AYARLARI
# Bu değerler yer gerçeği BİLİNEN sahne kareleri üzerinde ÖLÇÜLEREK seçildi.
# Değiştirmeden önce ve sonra `python3 testler/test_gramer.py` vb. çalıştır.
# ═══════════════════════════════════════════════════════════════════════

# Kırpmanın ölçekleneceği hedef yükseklik — doğruluğu belirleyen EN ÖNEMLİ
# parametre. 4 araç / 41 kare üzerinde ölçüldü:
#   230 -> %29 kare doğruluğu | 380 -> %63 | 620 -> %88 | 700+ tekrar düşüyor
HEDEF_PLAKA_YUKSEKLIGI=620
AZAMI_OLCEK=10.0

# Kabul eşikleri — yanlış cevap vermektense susmak tercih edilir.
MIN_PLAKA_GUVENI=0.55
MIN_MUTABAKAT_KARE=2
TEK_KARE_KESIN_GUVEN=0.88
TEK_KARE_MIN_PAY=0.35
# Kazanan aday tüm kanıtın en az bu kadarına sahip olmalı. Doğrulanmış
# okumalar %48+ paya sahipti; uydurma sonuçlar %28-30'da kalıyordu.
MIN_KANIT_PAYI=0.35

# Plaka kutusu geçerlilik filtreleri
PLAKA_CONF_ESIGI=0.35
PLAKA_IMGSZ=1280
PLAKA_MIN_GENISLIK=100
PLAKA_EN_BOY_MIN=1.6
PLAKA_EN_BOY_MAX=7.0
# Plaka, aracın bu oranından fazlasını kaplayamaz — kamyonet kapısındaki firma
# yazısını eler (gerçek plakalar %2.6-5.2, kapı yazısı %16.4 ölçüldü).
PLAKA_MAKS_ARAC_ORANI=0.10
# Plaka yalnızca tespit edilen bir aracın kutusu içinde aranır. Arka plandaki
# sabit tabelaların elenmesinin asıl yolu budur.
PLAKA_ARAC_ZORUNLU=true

# Episode (araç geçişi) zamanlaması
ARAC_TESPIT_CONF=0.45
ARAC_AYRILMA_BOSLUGU=3.0
MAKS_TOPLAMA_SANIYESI=12.0
OCR_KARE_SAYISI=14
ERKEN_CIKIS_OY=3
ERKEN_CIKIS_GUVEN=0.95
VARYANT_ERKEN_CIKIS=0.95
MIN_KESKINLIK=60.0

# Aynı aracın tekrar tekrar kaydedilmesini engelleyen ayarlar.
# COOLDOWN konumsaldır: araç aynı yerde durdukça süre tazelenir.
COOLDOWN_SANIYE=15.0
COOLDOWN_IOU_ESIGI=0.5
# Aynı plakanın tekrar gönderilmeden önce beklenmesi gereken süre (saniye).
AYNI_PLAKA_BEKLEME=120.0

# Üst filigran/tarih-saat bandını karart (0 = kapalı)
UST_MASKE_ORANI=0.12
HEARTBEAT_SANIYE=120.0
